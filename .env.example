# Yahoo Fantasy API OAuth 2.0 credentials
# Register at: https://developer.yahoo.com/apps/create/
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=http://localhost:3000/api/auth/callback

# League configuration
YAHOO_LEAGUE_ID=655705
# Game key changes each NFL season — discover via API or check Yahoo docs
YAHOO_GAME_KEY=nfl

# Cache: Vercel KV (production) — leave blank for local in-memory cache
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cron job secret — protects the /api/cron/refresh endpoint
CRON_SECRET=
